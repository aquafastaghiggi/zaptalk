# ──────────────────────────────────────────────
#  ZapTalk — Configurações de ambiente (MVP)
# ──────────────────────────────────────────────

# App
APP_NAME=ZapTalk
APP_VERSION=0.1.0
DEBUG=true
SECRET_KEY=troque_essa_chave_por_algo_seguro_em_producao

# Banco de dados (SQLite local para MVP)
DATABASE_URL=sqlite+aiosqlite:///./zaptalk.db

# Redis (opcional - não obrigatório no MVP local)
# REDIS_URL=redis://localhost:6379/0

# Evolution API
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=zaptalk_secret_key_change_me

# Frontend public URL
FRONTEND_PUBLIC_URL=http://localhost:5173

# SMTP (opcional para convites e recuperação de senha)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=ZapTalk
SMTP_USE_TLS=true
SMTP_USE_SSL=false

# IA (desativada por padrao)
AI_ENABLED=false
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
AI_MODEL_SUMMARY=gpt-5.4-mini
AI_MODEL_SUGGEST_REPLY=gpt-5.4-mini
AI_MODEL_CLASSIFY=gpt-5.4-mini
AI_MODEL_TRANSFER_SUMMARY=gpt-5.4
AI_MODEL_SENTIMENT=gpt-5.4-mini
AI_MAX_CONTEXT_MESSAGES=12
AI_MAX_CONTEXT_NOTES=8
AI_MAX_CONTEXT_TRANSFERS=8

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=480
ALGORITHM=HS256

# CORS (desenvolvimento)
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:5173"]
